 // 1. Core Product Definition Model
model Product {
  id            String           @id @default(uuid())
  name          String
  category      String
  description   String?          @db.Text
  stockStatus   String           @default("In Stock")
  badgeType     String           @default("None")
  images        Json             
  availableCuts Json             
  variants      ProductVariant[] 
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// 2. Dynamic Weight Pricing Scale Variant Model
model ProductVariant {
  id              String   @id @default(uuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight          String   
  cleanedWeight   String?  
  originalPrice   Float
  sellingPrice    Float
  discountPercent Int
}